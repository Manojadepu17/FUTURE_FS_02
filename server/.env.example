# Server Configuration
PORT=5000
NODE_ENV=production

# Database Dialect: sqlite or mysql
DB_DIALECT=mysql

# Database Configuration (MySQL)
# Get these from your MySQL provider (Railway, PlanetScale, Aiven, etc.)
DB_HOST=your_mysql_host_here
DB_PORT=3306
DB_NAME=mini_crm
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here

# JWT Secret (CRITICAL: Use a secure random string in production)
# Generated secure secret - you can use this or generate a new one
JWT_SECRET=8f7c3b2a1e9d4f6c8b5a3e7d2f9c1b8e4a6d3c9f7e2b5d8a1c4e7f9b2d6a3c5e8f1b4d7a2c5e9f3b6d8a1e4c7f2b9d5a8c3e6f1b7d4a9c2e5f8b3d6a1c4

# Client URL (Your frontend URL - Vercel, Netlify, or Replit frontend)
# Examples:
# - Vercel: https://mini-crm.vercel.app
# - Netlify: https://mini-crm.netlify.app
# - Replit: https://your-repl-name.your-username.repl.co
CLIENT_URL=https://your-frontend-url-here
