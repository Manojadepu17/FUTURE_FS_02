# Replit configuration for Mini CRM Backend
run = "cd server && npm install && npm start"
entrypoint = "server/server.js"

[nix]
channel = "stable-22_11"

[env]
PORT = "5000"
NODE_ENV = "production"

[deployment]
run = ["sh", "-c", "cd server && npm install && npm start"]

[[ports]]
localPort = 5000
externalPort = 80
